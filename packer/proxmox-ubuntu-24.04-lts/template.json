          "title": "SSH Timeout",
          "required": false,
          "default": "30m",
          "config": {
            "placeholder": "30m"
          }
        },
        {
          "name": "http_interface",
          "type": "str",
          "title": "HTTP Interface",
          "required": false,
          "config": {
            "placeholder": "en0"
          }
        }
