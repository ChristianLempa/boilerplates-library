{
  "slug": "proxmox-ubuntu-24-04-lts-packer",
  "kind": "packer",
  "metadata": {
    "name": "Proxmox Ubuntu 24.04 LTS Template",
    "description": "Builds an Ubuntu 24.04 LTS cloud-init VM template on Proxmox with the HashiCorp Proxmox Packer plugin and autoinstall.",
    "tags": [
      "proxmox",
      "ubuntu",
      "packer",
      "cloud-init"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "ubuntu",
      "color": "orange"
    },
    "draft": false,
    "version": {
      "name": "1.0.0-1",
      "source_dep_name": "github.com/hashicorp/proxmox",
      "source_dep_version": "\u003e= 1.1.3"
    }
  },
  "variables": [
    {
      "name": "credentials",
      "title": "Credentials",
      "items": [
        {
          "name": "proxmox_api_url",
          "type": "str",
          "title": "Proxmox API URL",
          "required": true,
          "default": "https://proxmox.example.com:8006/api2/json",
          "config": {
            "placeholder": "https://proxmox.example.com:8006/api2/json"
          }
        },
        {
          "name": "proxmox_api_token_id",
          "type": "str",
          "title": "Proxmox API Token ID",
          "required": true,
          "default": "packer@pve!token",
          "config": {
            "placeholder": "packer@pve!token"
          }
        },
        {
          "name": "proxmox_api_token_secret",
          "type": "str",
          "title": "Proxmox API Token Secret",
          "required": true,
          "description": "Packer runtime secret for the Proxmox API token. Prefer overriding this at generation time or via pkrvars instead of committing real secrets.",
          "config": {
            "placeholder": "CHANGEME"
          }
        }
      ]
    },
    {
      "name": "proxmox",
      "title": "Proxmox",
      "items": [
        {
          "name": "proxmox_node",
          "type": "str",
          "title": "Proxmox Node",
          "required": true,
          "config": {
            "placeholder": "prx-prod-1"
          }
        },
        {
          "name": "vm_name",
          "type": "str",
          "title": "Template VM Name",
          "required": true,
          "default": "pkr-ubuntu-24.04",
          "config": {
            "placeholder": "pkr-ubuntu-24.04"
          }
        },
        {
          "name": "template_description",
          "type": "str",
          "title": "Template Description",
          "required": false,
          "default": "Ubuntu 24.04 LTS (Noble Numbat)",
          "config": {
            "placeholder": "Ubuntu 24.04 LTS (Noble Numbat)"
          }
        },
        {
          "name": "iso_file",
          "type": "str",
          "title": "ISO File",
          "required": true,
          "default": "local:iso/ubuntu-24.04-live-server-amd64.iso",
          "config": {
            "placeholder": "local:iso/ubuntu-24.04-live-server-amd64.iso"
          }
        },
        {
          "name": "iso_storage_pool",
          "type": "str",
          "title": "ISO Storage Pool",
          "required": false,
          "default": "local",
          "config": {
            "placeholder": "local"
          }
