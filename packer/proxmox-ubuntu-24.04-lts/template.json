          "name": "locale",
          "type": "str",
          "title": "Locale",
          "required": false,
          "default": "en_US",
          "config": {
            "placeholder": "en_US"
          }
        },
        {
          "name": "keyboard_layout",
          "type": "str",
          "title": "Keyboard Layout",
          "required": false,
          "default": "de",
          "config": {
            "placeholder": "de"
          }
        },
        {
          "name": "timezone",
          "type": "str",
          "title": "Timezone",
          "required": false,
          "default": "Europe/Berlin",
          "config": {
            "placeholder": "Europe/Berlin"
