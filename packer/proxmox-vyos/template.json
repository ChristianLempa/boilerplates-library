{
  "slug": "proxmox-vyos",
  "kind": "packer",
  "metadata": {
    "name": "Proxmox VyOS Template",
    "description": "Builds a VyOS VM template on Proxmox for virtual routers, network labs, and firewall testing.",
    "tags": [
      "proxmox",
      "packer"
    ],
    "icon": {
      "provider": "mdi",
      "id": "router-network",
      "color": "cyan"
    },
    "draft": false,
    "version": {
      "name": "1.0.0",
      "source_dep_name": "github.com/hashicorp/proxmox",
      "source_dep_version": ">= 1.1.3"
    }
  },
  "variables": [
    {
      "title": "Proxmox",
      "name": "proxmox",
      "items": [
        {
          "name": "proxmox_node",
          "type": "str",
          "title": "Proxmox Node",
          "required": true,
          "config": {
            "placeholder": "prx-prod-1"
          }
        },
        {
          "name": "vm_name",
          "type": "str",
          "title": "Template VM Name",
          "required": true,
          "default": "pkr-vyos",
          "config": {
            "placeholder": "pkr-vyos"
          }
        },
        {
          "name": "template_description",
          "type": "str",
          "title": "Template Description",
          "required": false,
          "default": "VyOS router template",
          "config": {
            "placeholder": "VyOS router template"
          }
        },
        {
          "name": "iso_file",
          "type": "str",
          "title": "ISO File",
          "required": true,
          "default": "local:iso/vyos-1.5-rolling-generic-amd64.iso",
          "config": {
            "placeholder": "local:iso/vyos-1.5-rolling-generic-amd64.iso"
          }
        },
        {
          "name": "iso_storage_pool",
          "type": "str",
          "title": "ISO Storage Pool",
          "required": false,
          "default": "local",
          "config": {
            "placeholder": "local"
          }
        },
        {
          "name": "cloud_init_storage_pool",
          "type": "str",
          "title": "Cloud-Init Storage Pool",
          "required": false,
          "default": "rbd",
          "config": {
            "placeholder": "rbd"
          }
        }
      ]
    },
    {
      "title": "Hardware",
      "name": "hardware",
      "items": [
        {
          "name": "cpu_cores",
          "type": "str",
          "title": "CPU Cores",
          "required": false,
          "default": "2",
          "config": {
            "placeholder": "2"
          }
        },
        {
          "name": "cpu_sockets",
          "type": "str",
          "title": "CPU Sockets",
          "required": false,
          "default": "1",
          "config": {
            "placeholder": "1"
          }
        },
        {
          "name": "memory",
          "type": "str",
          "title": "Memory (MiB)",
          "required": false,
          "default": "2048",
          "config": {
            "placeholder": "2048"
          }
        },
        {
          "name": "disk_size",
          "type": "str",
          "title": "Disk Size",
          "required": false,
          "default": "20G",
          "config": {
            "placeholder": "20G"
          }
        },
        {
          "name": "disk_storage_pool",
          "type": "str",
          "title": "Disk Storage Pool",
          "required": false,
          "default": "rbd",
          "config": {
            "placeholder": "rbd"
          }
        },
        {
          "name": "network_bridge",
          "type": "str",
          "title": "Network Bridge",
          "required": false,
          "default": "vmbr1",
          "config": {
            "placeholder": "vmbr1"
          }
        }
      ]
    },
    {
      "title": "Guest",
      "name": "guest",
      "items": [
        {
          "name": "locale",
          "type": "str",
          "title": "Locale",
          "required": false,
          "default": "en_US",
          "config": {
            "placeholder": "en_US"
          }
        },
        {
          "name": "keyboard_layout",
          "type": "str",
          "title": "Keyboard Layout",
          "required": false,
          "default": "de",
          "config": {
            "placeholder": "de"
          }
        },
        {
          "name": "timezone",
          "type": "str",
          "title": "Timezone",
          "required": false,
          "default": "Europe/Berlin",
          "config": {
            "placeholder": "Europe/Berlin"
          }
        },
        {
          "name": "admin_username",
          "type": "str",
          "title": "Admin Username",
          "required": true,
          "default": "admin",
          "config": {
            "placeholder": "admin"
          }
        },
        {
          "name": "ssh_password",
          "type": "str",
          "title": "SSH Password",
          "required": false,
          "description": "Optional placeholder used by shared Packer variable defaults; Talos/VyOS templates use communicator none by default.",
          "config": {
            "placeholder": "CHANGEME"
          }
        }
      ]
    },
    {
      "title": "Build",
      "name": "build",
      "items": [
        {
          "name": "packer_source_name",
          "type": "str",
          "title": "Packer Source Name",
          "required": false,
          "default": "pkr-vyos",
          "config": {
            "placeholder": "pkr-vyos"
          }
        },
        {
          "name": "boot_wait",
          "type": "str",
          "title": "Boot Wait",
          "required": false,
          "default": "20s",
          "config": {
            "placeholder": "20s"
          }
        },
        {
          "name": "ssh_timeout",
          "type": "str",
          "title": "SSH Timeout",
          "required": false,
          "default": "20m",
          "config": {
            "placeholder": "20m"
          }
        },
        {
          "name": "http_interface",
          "type": "str",
          "title": "HTTP Interface",
          "required": false,
          "default": "en0",
          "config": {
            "placeholder": "en0"
          }
        }
      ]
    }
  ]
}
