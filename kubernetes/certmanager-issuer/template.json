{
  "slug": "certmanager-issuer",
  "kind": "kubernetes",
  "metadata": {
    "name": "Cert-Manager Issuer",
    "description": "Namespace-scoped cert-manager ACME Issuer for requesting certificates with HTTP-01 or Cloudflare DNS-01 challenge validation.",
    "tags": [
      "cert-manager",
      "tls",
      "acme",
      "letsencrypt"
    ],
    "icon": {
      "provider": "mdi",
      "id": "certificate-outline",
      "color": "blue"
    },
    "draft": false,
    "version": {
      "name": "v1.20.2",
      "source_dep_name": "cert-manager/cert-manager",
      "source_dep_version": "v1.20.2"
    }
  },
  "variables": [
    {
      "title": "Issuer",
      "name": "issuer",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Issuer name",
          "required": false,
          "default": "letsencrypt-prod",
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "config": {
            "placeholder": "default"
          }
        },
        {
          "name": "acme_email",
          "type": "str",
          "title": "ACME email",
          "required": true,
          "default": "admin@example.com",
          "config": {
            "placeholder": "admin@example.com"
          }
        },
        {
          "name": "acme_server",
          "type": "str",
          "title": "ACME server URL",
          "required": false,
          "default": "https://acme-v02.api.letsencrypt.org/directory",
          "config": {
            "placeholder": "https://acme-v02.api.letsencrypt.org/directory"
          }
        },
        {
          "name": "account_secret_name",
          "type": "str",
          "title": "Account key secret",
          "required": false,
          "default": "letsencrypt-prod-account-key",
          "config": {
            "placeholder": "letsencrypt-prod-account-key"
          }
        }
      ]
    },
    {
      "title": "Solver",
      "name": "solver",
      "items": [
        {
          "name": "solver_type",
          "type": "enum",
          "title": "Challenge solver",
          "required": false,
          "default": "cloudflare-dns01",
          "config": {
            "options": [
              "cloudflare-dns01",
              "http01"
            ]
          }
        },
        {
          "name": "http01_ingress_class",
          "type": "str",
          "title": "HTTP-01 ingress class",
          "required": false,
          "default": "traefik",
          "needs": [
            "solver_type=http01"
          ],
          "config": {
            "placeholder": "traefik"
          }
        },
        {
          "name": "cloudflare_api_token_secret_name",
          "type": "str",
          "title": "Cloudflare API token secret",
          "required": false,
          "default": "cloudflare-api-token-secret",
          "needs": [
            "solver_type=cloudflare-dns01"
          ],
          "config": {
            "placeholder": "cloudflare-api-token-secret"
          }
        },
        {
          "name": "cloudflare_api_token_secret_key",
          "type": "str",
          "title": "Cloudflare API token key",
          "required": false,
          "default": "api-token",
          "needs": [
            "solver_type=cloudflare-dns01"
          ],
          "config": {
            "placeholder": "api-token"
          }
        },
        {
          "name": "dns_zones",
          "type": "str",
          "title": "DNS zone selector",
          "required": false,
          "default": "",
          "description": "Optional comma-separated DNS zones this solver should match.",
          "needs": [
            "solver_type=cloudflare-dns01"
          ],
          "config": {
            "placeholder": "example.com,home.arpa"
          }
        }
      ]
    }
  ]
}
