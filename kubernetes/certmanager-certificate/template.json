{
  "slug": "certmanager-certificate",
  "kind": "kubernetes",
  "metadata": {
    "name": "Cert-Manager Certificate",
    "description": "Cert-manager Certificate resource for requesting a TLS certificate from an Issuer or ClusterIssuer and storing it in a Kubernetes Secret.",
    "tags": [
      "cert-manager",
      "tls",
      "certificate"
    ],
    "icon": {
      "provider": "mdi",
      "id": "certificate-outline",
      "color": "blue"
    },
    "draft": false,
    "version": {
      "name": "v1.20.2",
      "source_dep_name": "cert-manager/cert-manager",
      "source_dep_version": "v1.20.2"
    }
  },
  "variables": [
    {
      "title": "Certificate",
      "name": "certificate",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Certificate name",
          "required": false,
          "default": "app-tls",
          "config": {
            "placeholder": "app-tls"
          }
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "config": {
            "placeholder": "default"
          }
        },
        {
          "name": "secret_name",
          "type": "str",
          "title": "TLS secret name",
          "required": false,
          "default": "app-tls",
          "config": {
            "placeholder": "app-tls"
          }
        },
        {
          "name": "dns_names",
          "type": "str",
          "title": "DNS names",
          "required": false,
          "default": "app.example.com",
          "description": "Comma-separated DNS names for the certificate.",
          "config": {
            "placeholder": "app.example.com,*.example.com"
          }
        },
        {
          "name": "common_name",
          "type": "str",
          "title": "Common name",
          "required": false,
          "default": "",
          "config": {
            "placeholder": "app.example.com"
          }
        }
      ]
    },
    {
      "title": "Issuer Reference",
      "name": "issuer",
      "items": [
        {
          "name": "issuer_name",
          "type": "str",
          "title": "Issuer name",
          "required": false,
          "default": "letsencrypt-prod",
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        },
        {
          "name": "issuer_kind",
          "type": "enum",
          "title": "Issuer kind",
          "required": false,
          "default": "ClusterIssuer",
          "config": {
            "options": [
              "ClusterIssuer",
              "Issuer"
            ]
          }
        },
        {
          "name": "issuer_group",
          "type": "str",
          "title": "Issuer group",
          "required": false,
          "default": "cert-manager.io",
          "config": {
            "placeholder": "cert-manager.io"
          }
        }
      ]
    },
    {
      "title": "Certificate Options",
      "name": "options",
      "items": [
        {
          "name": "duration",
          "type": "str",
          "title": "Duration",
          "required": false,
          "default": "2160h",
          "config": {
            "placeholder": "2160h"
          }
        },
        {
          "name": "renew_before",
          "type": "str",
          "title": "Renew before",
          "required": false,
          "default": "360h",
          "config": {
            "placeholder": "360h"
          }
        },
        {
          "name": "private_key_algorithm",
          "type": "enum",
          "title": "Private key algorithm",
          "required": false,
          "default": "ECDSA",
          "config": {
            "options": [
              "ECDSA",
              "RSA"
            ]
          }
        },
        {
          "name": "private_key_size",
          "type": "int",
          "title": "Private key size",
          "required": false,
          "default": 256,
          "config": {
            "placeholder": "256"
          }
        },
        {
          "name": "private_key_rotation_policy",
          "type": "enum",
          "title": "Private key rotation policy",
          "required": false,
          "default": "Always",
          "config": {
            "options": [
              "Always",
              "Never"
            ]
          }
        }
      ]
    }
  ]
}
