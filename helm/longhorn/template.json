{
  "slug": "longhorn-helm",
  "kind": "helm",
  "metadata": {
    "name": "Longhorn",
    "description": "Helm release values for Longhorn, a distributed block storage system for Kubernetes with built-in backup, snapshots, and disaster recovery.",
    "tags": [],
    "icon": {
      "provider": "selfhst",
      "id": "rancher-longhorn",
      "color": "rose"
    },
    "draft": false,
    "version": {
      "name": "1.11.2",
      "source_dep_name": "longhorn/longhorn",
      "source_dep_version": "1.11.2"
    }
  },
  "variables": [
    {
      "title": "Backup Configuration",
      "name": "backup",
      "items": [
        {
          "name": "backup_enabled",
          "type": "bool",
          "title": "Backup",
          "required": false,
          "default": false
        },
        {
          "name": "backup_target",
          "type": "str",
          "title": "Backup Target",
          "required": false,
          "description": "Backup target URL (e.g., s3://bucket or nfs://server/path)",
          "needs": [
            "backup_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Longhorn UI",
      "name": "ui",
      "items": [
        {
          "name": "ui_replicas",
          "type": "int",
          "title": "UI Replicas",
          "required": false,
          "default": 1,
          "description": "Number of Longhorn UI replicas",
          "config": {
            "slider": true,
            "min": 1,
            "max": 10,
            "step": 1,
            "placeholder": "1",
            "unit": "replicas"
          }
        }
      ]
    }
  ],
  "config": {
    "helm": {
      "chart": "longhorn/longhorn",
      "repository_url": "https://charts.longhorn.io",
      "version": "1.11.2"
    }
  },
  "file_metadata": {}
}
